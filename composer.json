{
    "name": "justbetter/laravel-sentry-filter-events",
    "description": " Lets you filter certain events in Sentry using a filter list ",
    "keywords": [
        "JustBetter",
        "laravel",
        "sentry"
    ],
    "homepage": "https://github.com/justbetter/laravel-sentry-filter-events",
    "license": "MIT",
    "authors": [
        {
            "name": "Jade",
            "email": "jade@justbetter.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.5",
        "laravel/framework": "^12.0|^13.0",
        "sentry/sentry-laravel": "^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.11|^11.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpunit/phpunit": "^12.5|^13.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "JustBetter\\LaravelSentryFilterEvents\\": "src/",
            "JustBetter\\LaravelSentryFilterEvents\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JustBetter\\LaravelSentryFilterEvents\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan --memory-limit=256M",
        "style": "pint --test",
        "quality": [
            "@style",
            "@analyse",
            "@test",
            "@coverage",
            "@rector"
        ],
        "coverage": "XDEBUG_MODE=coverage php -d memory_limit=2G vendor/bin/phpunit --coverage-text --only-summary-for-coverage-text | grep -c \"100.00%\" | grep -q \"^3$\" && exit 0 || exit 1",
        "rector": "rector process --dry-run"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JustBetter\\LaravelSentryFilterEvents\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
